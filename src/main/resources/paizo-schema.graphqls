                {
                    "kind": "INPUT_OBJECT",
                    "name": "SearchProductsFiltersInput",
                    "description": "Object containing available search filters for use when querying Products.",
                    "fields": null,
                    "inputFields":
                    [
                        {
                            "name": "searchTerm",
                            "description": "Textual search term. Used to search for products based on text entered by a shopper, typically in a search box. Searches against several fields on the product including Name, SKU, and Description.",
                            "type":
                            {
                                "kind": "SCALAR",
                                "name": "String",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "price",
                            "description": "Search by price range. At least a minPrice or maxPrice must be supplied.",
                            "type":
                            {
                                "kind": "INPUT_OBJECT",
                                "name": "PriceSearchFilterInput",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "rating",
                            "description": "Filter by rating. At least a minRating or maxRating must be supplied. This filter will do nothing unless your store has the Product Filtering feature available on your plan and enabled. If it is supplied when your store does not have the feature enabled, it will be silently ignored.",
                            "type":
                            {
                                "kind": "INPUT_OBJECT",
                                "name": "RatingSearchFilterInput",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "categoryEntityId",
                            "description": "Filter by products belonging to a single Category. This is intended for use when presenting a Category page in a PLP experience. This argument must be used in order for custom product sorts and custom product filtering settings targeted at a particular category to take effect.",
                            "type":
                            {
                                "kind": "SCALAR",
                                "name": "Int",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "categoryEntityIds",
                            "description": "Filter by products belonging to any of the specified Categories. Intended for Advanced Search and Faceted Search/Product Filtering use cases, not for a page for a specific Category.",
                            "type":
                            {
                                "kind": "LIST",
                                "name": null,
                                "ofType":
                                {
                                    "kind": "NON_NULL",
                                    "name": null,
                                    "ofType":
                                    {
                                        "kind": "SCALAR",
                                        "name": "Int",
                                        "ofType": null
                                    }
                                }
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "searchSubCategories",
                            "description": "Boolean argument to determine whether products within sub-Categories will be returned when filtering products by Category. Defaults to False if not supplied.",
                            "type":
                            {
                                "kind": "SCALAR",
                                "name": "Boolean",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "brandEntityIds",
                            "description": "Filter by products belonging to any of the specified Brands.",
                            "type":
                            {
                                "kind": "LIST",
                                "name": null,
                                "ofType":
                                {
                                    "kind": "NON_NULL",
                                    "name": null,
                                    "ofType":
                                    {
                                        "kind": "SCALAR",
                                        "name": "Int",
                                        "ofType": null
                                    }
                                }
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "productAttributes",
                            "description": "Filter by the attributes of products such as Product Options and Product Custom Fields. This filter will do nothing unless your store has the Product Filtering feature available on your plan and enabled. If it is supplied when your store does not have the feature enabled, it will be silently ignored.",
                            "type":
                            {
                                "kind": "LIST",
                                "name": null,
                                "ofType":
                                {
                                    "kind": "NON_NULL",
                                    "name": null,
                                    "ofType":
                                    {
                                        "kind": "INPUT_OBJECT",
                                        "name": "ProductAttributeSearchFilterInput",
                                        "ofType": null
                                    }
                                }
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "isFreeShipping",
                            "description": "Filters by Products which have explicit Free Shipping configured within the catalog. If not supplied, the Free Shipping status of products will not be considered when returning the list of products.",
                            "type":
                            {
                                "kind": "SCALAR",
                                "name": "Boolean",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "isFeatured",
                            "description": "Filters by Products which have explicitly been marked as Featured within the catalog. If not supplied, the Featured status of products will not be considered when returning the list of products.",
                            "type":
                            {
                                "kind": "SCALAR",
                                "name": "Boolean",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "hideOutOfStock",
                            "description": "When set to True, hides products which are out of stock. Defaults to False. This filter will do nothing unless your store has the Product Filtering feature available on your plan and enabled. If it is supplied when your store does not have the feature enabled, it will be silently ignored.",
                            "type":
                            {
                                "kind": "SCALAR",
                                "name": "Boolean",
                                "ofType": null
                            },
                            "defaultValue": null
                        },
                        {
                            "name": "categoryIdsFilter",
                            "description": "Filter by products belonging to any or all of the specified Categories. Intended for Advanced Search and Faceted Search/Product Filtering use cases, not for a page for a specific Category.",
                            "type":
                            {
                                "kind": "INPUT_OBJECT",
                                "name": "CategoryEntityIdsFilterInput",
                                "ofType": null
                            },
                            "defaultValue": null
                        }
